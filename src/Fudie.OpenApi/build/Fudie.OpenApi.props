<Project>
  <PropertyGroup>
    <FudieOpenApiFolder Condition="'$(FudieOpenApiFolder)' == ''">OpenApi</FudieOpenApiFolder>
  </PropertyGroup>
  <ItemGroup>
    <Content Include="$(FudieOpenApiFolder)\**\*.yaml" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>
  <ItemGroup>
    <Using Include="Fudie.OpenApi" />
  </ItemGroup>
</Project>
